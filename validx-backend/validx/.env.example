PORT=4000
CORS_ORIGINS=http://localhost:8080,http://localhost:4000

# Supabase Auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Local admin row used to authorize matching Supabase admin users.
# Create/invite this same email in Supabase Auth before signing in.
ADMIN_EMAIL=admin@validx.com
ADMIN_PASSWORD=change-this-local-bootstrap-password

# Legacy JWT auth remains available for old API clients.
JWT_SECRET=change-this-to-a-long-random-string
